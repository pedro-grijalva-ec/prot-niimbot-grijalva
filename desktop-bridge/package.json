{
  "name": "niimbot-windows-bridge",
  "version": "1.0.0",
  "description": "Puente de impresión local para Grijalva Joyería",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder --publish always",
    "start": "electron .",
    "electron:dev": "electron ."
  },
  "author": "pedro-grijalva-ec",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/pedro-grijalva-ec/prot-niimbot-grijalva.git"
  },
  "dependencies": {
    "@mmote/niimblue-node": "^0.0.12",
    "sharp": "^0.34.5",
    "axios": "^1.8.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.477.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "autoprefixer": "^10.4.16",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.31",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.grijalva.niimbot-bridge",
    "productName": "Niimbot Bridge",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "publish": [
        "github"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "pedro-grijalva-ec",
      "repo": "prot-niimbot-grijalva"
    }
  }
}